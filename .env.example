# Telegram Bot Token from @BotFather
BOT_TOKEN=123456:your_bot_token_here

# Default is whitelist mode. Fill at least OWNER_ID or ALLOWED_USER_IDS,
# unless you explicitly set PUBLIC_ACCESS=true.
OWNER_ID=123456789
ALLOWED_USER_IDS=
PUBLIC_ACCESS=false

# Optional runtime paths inside container
DATA_DIR=/app/data
TMP_DIR=/tmp/ip-tools-telegram-bot
